<?xml version="1.0" encoding="UTF-8"?>

<!--
    Custom Action definitions for Sales Buddy MSI.

    Install: runs scripts/install.ps1 with flags from MSI properties
    Uninstall: runs scripts/uninstall.ps1 -Silent

    These use WiX Quiet Execution custom actions to run PowerShell
    without showing a terminal window.
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

    <Fragment>

        <!-- ================================================================
             INSTALL: Run install.ps1 with checkbox flags
             ================================================================ -->

        <!-- Build the install command line from MSI properties -->
        <SetProperty Id="InstallCommand"
                     Value="powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]scripts\install.ps1&quot; -Shortcuts -DesktopShortcut -LaunchBrowser"
                     Before="InstallAction"
                     Sequence="execute"
                     Condition="LAUNCH_APP AND CREATE_SHORTCUTS AND CREATE_DESKTOP_SHORTCUT" />

        <SetProperty Id="InstallCommandNoLaunch"
                     Value="powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]scripts\install.ps1&quot; -Shortcuts -DesktopShortcut"
                     Before="InstallAction"
                     Sequence="execute"
                     Condition="(NOT LAUNCH_APP) AND CREATE_SHORTCUTS AND CREATE_DESKTOP_SHORTCUT" />

        <SetProperty Id="InstallCommandMinimal"
                     Value="powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]scripts\install.ps1&quot;"
                     Before="InstallAction"
                     Sequence="execute"
                     Condition="(NOT CREATE_SHORTCUTS) AND (NOT CREATE_DESKTOP_SHORTCUT)" />

        <CustomAction Id="InstallAction"
                      Directory="INSTALLFOLDER"
                      ExeCommand="[InstallCommand]"
                      Execute="deferred"
                      Impersonate="yes"
                      Return="check" />

        <!-- ================================================================
             UNINSTALL: Run uninstall.ps1 -Silent
             ================================================================ -->

        <Property Id="UninstallCommand"
                  Value="powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]scripts\uninstall.ps1&quot; -Silent" />

        <CustomAction Id="UninstallAction"
                      Directory="INSTALLFOLDER"
                      ExeCommand="[UninstallCommand]"
                      Execute="deferred"
                      Impersonate="yes"
                      Return="ignore" />

        <!-- ================================================================
             POST-INSTALL: Launch browser (conditional on checkbox)
             ================================================================ -->

        <Property Id="WixShellExecTarget" Value="http://localhost:5151" />
        <CustomAction Id="LaunchApp"
                      Directory="INSTALLFOLDER"
                      ExeCommand="cmd.exe /c start http://localhost:5151"
                      Impersonate="yes"
                      Return="asyncNoWait" />

        <!-- ================================================================
             Schedule custom actions in InstallExecuteSequence
             ================================================================ -->

        <InstallExecuteSequence>
            <!-- Install action runs after files are installed -->
            <Custom Action="InstallAction" After="InstallFiles" Condition="NOT REMOVE" />
            <!-- Uninstall action runs before files are removed -->
            <Custom Action="UninstallAction" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
            <!-- Launch browser after install completes (if checkbox checked) -->
            <Custom Action="LaunchApp" After="InstallFinalize" Condition="(NOT REMOVE) AND LAUNCH_APP" />
        </InstallExecuteSequence>

    </Fragment>

</Wix>
